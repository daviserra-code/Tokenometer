{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Tokenometer Desktop",
  "version": "0.1.0",
  "identifier": "cloud.tokenometer.desktop",
  "build": {
    "frontendDist": "../desktop-shell"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Tokenometer",
        "width": 1440,
        "height": 920,
        "minWidth": 1120,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi"
    ],
    "shortDescription": "Desktop shell for the hosted Tokenometer web app.",
    "longDescription": "Tokenometer Desktop is a lightweight Tauri shell that opens the hosted Tokenometer platform and prepares the path for future local integrations.",
    "createUpdaterArtifacts": false,
    "windows": {
      "digestAlgorithm": "sha256"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}

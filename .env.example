# Local PostgreSQL via docker-compose
DATABASE_URL="postgresql://tokenradar:tokenradar@localhost:5433/tokenradar?schema=public"
INGEST_ENC_KEY="replace-with-32-char-random-string"
CRON_SECRET="replace-with-32-char-random-cron-secret"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
SERVER_ACTION_ALLOWED_ORIGINS="localhost:3000"
POSTGRES_PASSWORD="tokenradar"

# Optional - enables /assistant Copilot. Without it the route returns 503.
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"

# Optional alt providers for the Copilot (auto-detected). Pin one with AI_PROVIDER=anthropic|google|mistral.
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-3-5-haiku-latest"
GOOGLE_GENERATIVE_AI_API_KEY="AIza..."
GOOGLE_MODEL="gemini-1.5-flash"
MISTRAL_API_KEY="..."
MISTRAL_MODEL="mistral-small-latest"
AI_PROVIDER=""

# GitHub Models (Copilot Pro+ / Pay-as-you-go)
GITHUB_TOKEN="github_pat_..."
GITHUB_MODEL="openai/gpt-4o-mini"
